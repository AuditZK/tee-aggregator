# Production Dockerfile with SEV-SNP attestation support.
#
# Reproducibility notes (SEC audit pass 5; SUP-02):
#   - Base images are pinned by digest (`image@sha256:<digest>`) for
#     reproducible builds. Bump the digest whenever you bump the tag —
#     resolve it with `docker buildx imagetools inspect <tag>`.
#   - snpguest is pinned to an explicit version + --locked so transitive crates
#     cannot drift between builds.
#   - Rust stable is preferred over nightly — nightly's tag mutates daily.

# snpguest build stage (AMD SEV-SNP attestation tool).
# snpguest 0.10.0 requires rustc >= 1.86, so the base image must stay at or above 1.86.
FROM rust:1.86-alpine@sha256:661d708cc863ce32007cf46807a72062a80d2944a6fae9e0d83742d2e04d5375 AS snpguest-builder

# perl + make are required because a transitive dep of snpguest 0.10.0
# (openssl-sys with the `vendored` feature) builds OpenSSL from source
# regardless of openssl-dev being present. Without perl, ./Configure
# fails with "Command 'perl' not found" — see commit history for the
# build trace that surfaced this.
RUN apk add --no-cache musl-dev openssl-dev openssl-libs-static git perl make
# Pin the snpguest version so a transitive crate bump doesn't silently change
# the binary embedded in every production build.
RUN cargo install snpguest --version 0.10.0 --root /usr/local --locked

# Go build stage.
# VULN-001: pinned to 1.26.4-alpine so stdlib CVEs fixed in 1.26.1 / 1.26.2
# (GO-2026-4947/4946/4870/4866/4865/4603/4602/4601/4600/4599), 1.26.3
# (GO-2026-4982/4980/4971/4918) and 1.26.4 (GO-2026-5037 crypto/x509,
# GO-2026-5039 net/textproto, GO-2026-5038 mime) are picked up
# deterministically. Pinned by digest (SUP-02) — bump it when bumping the tag.
FROM golang:1.26.5-alpine@sha256:0178a641fbb4858c5f1b48e34bdaabe0350a330a1b1149aabd498d0699ff5fb2 AS builder

WORKDIR /app

# Install dependencies
RUN apk add --no-cache git ca-certificates tzdata

# Copy go mod files
COPY go.mod go.sum ./
RUN go mod download

# Copy source
COPY . .

# Build with -trimpath for reproducible builds
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build \
    -trimpath \
    -ldflags="-w -s" \
    -o /enclave \
    ./cmd/enclave

# Runtime stage.
FROM alpine:3.20@sha256:d9e853e87e55526f6b2917df91a2115c36dd7c696a35be12163d44e6e2a4b6bc

WORKDIR /app

# Install runtime dependencies
RUN apk add --no-cache ca-certificates tzdata wget

# Copy snpguest binary for SEV-SNP attestation
COPY --from=snpguest-builder /usr/local/bin/snpguest /usr/local/bin/snpguest

# Copy Go binary
COPY --from=builder /enclave /app/enclave

# Copy migrations
COPY --from=builder /app/migrations /app/migrations

# Create non-root user and cache directory for VCEK certs
# NOTE: For SEV-SNP /dev/sev-guest access, you may need to run as root
# or configure device permissions. Comment out USER line if needed.
RUN adduser -D -g '' enclave && \
    mkdir -p /var/cache/enclave/certs && \
    chown enclave:enclave /var/cache/enclave/certs
USER enclave

# Expose ports: REST, gRPC, Log Stream, Metrics
EXPOSE 8080 50051 50052 9090

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget --no-check-certificate -qO/dev/null https://localhost:8080/health || exit 1

# Run
ENTRYPOINT ["/app/enclave"]
